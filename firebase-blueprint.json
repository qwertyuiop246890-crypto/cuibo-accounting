{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["email"]
    },
    "PaymentAccount": {
      "title": "Payment Account",
      "description": "A payment method like JPY Cash, Credit Card, or IC Card.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "balance": { "type": "number" },
        "currency": { "type": "string", "description": "Currency code like JPY, TWD, USD" },
        "order": { "type": "number", "description": "Display order of the account" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "balance", "currency"]
    },
    "Receipt": {
      "title": "Receipt",
      "description": "A receipt for a purchase.",
      "type": "object",
      "properties": {
        "photoUrl": { "type": "string" },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "storeName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" },
        "currency": { "type": "string" },
        "paymentAccountId": { "type": "string" },
        "category": { "type": "string", "enum": ["進貨", "私人"] },
        "subCategory": { "type": "string", "enum": ["飲食", "服飾", "居住", "交通", "教育", "娛樂", "其他"] },
        "notes": { "type": "string" },
        "totalDiscount": { "type": "number", "description": "Total discount amount" },
        "totalTaxRefund": { "type": "number", "description": "Total tax refund amount" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "totalAmount", "paymentAccountId", "category"]
    },
    "Item": {
      "title": "Item",
      "description": "An item on a receipt.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Original name from receipt" },
        "translatedName": { "type": "string", "description": "Traditional Chinese translation" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "quantity"]
    },
    "Transfer": {
      "title": "Transfer",
      "description": "An internal transfer between payment accounts.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "fromAccountId": { "type": "string" },
        "toAccountId": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "amount", "fromAccountId", "toAccountId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/users/{userId}/paymentAccounts/{accountId}": {
      "schema": { "$ref": "#/entities/PaymentAccount" },
      "description": "Payment accounts created by the user."
    },
    "/users/{userId}/receipts/{receiptId}": {
      "schema": { "$ref": "#/entities/Receipt" },
      "description": "Receipts created by the user."
    },
    "/users/{userId}/receipts/{receiptId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/Item" },
      "description": "Items on a receipt."
    },
    "/users/{userId}/transfers/{transferId}": {
      "schema": { "$ref": "#/entities/Transfer" },
      "description": "Transfers created by the user."
    }
  }
}
